# ---- Supabase (from your project's Settings > API) ----
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — server only, NEVER prefix with NEXT_PUBLIC:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Control panel auth ----
# The single shared password your helpers type in to log in:
CONTROL_PASSWORD=change-me-to-something-long

# Random string used to sign the login session cookie.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=change-me-too
