# ---- Supabase (from your project's Settings > API) ----
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — server only, used by the timestamp export to read all events.
# NEVER prefix this with NEXT_PUBLIC:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Helper accounts are managed in the Supabase dashboard
# (Authentication > Users). No password env var needed.
